rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: rsvps
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-50 chars)
    //   - attendance: string (required, 'present' or 'absent')
    //   - message: string (required, 1-500 chars)
    //   - timestamp: timestamp (required)
    //   - likes: number (required, >= 0)
    //   - likedBy: list (required, max 1000 items)
    //
    // Collection: guests
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - slug: string (required, 1-100 chars)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             ((request.auth.token.email == "estabantu5@gmail.com" || request.auth.token.email == "estaaliansyah@gmail.com") && 
              request.auth.token.email_verified == true);
    }

    function isValidRSVP(data) {
      return data.keys().hasAll(['name', 'attendance', 'message', 'timestamp', 'likes', 'likedBy']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 50 &&
             data.attendance in ['present', 'absent'] &&
             data.message is string && data.message.size() >= 1 && data.message.size() <= 500 &&
             data.timestamp is timestamp &&
             data.likes is number && data.likes >= 0 &&
             data.likedBy is list && data.likedBy.size() <= 1000;
    }

    function isValidGuest(data) {
      return data.keys().hasAll(['name', 'slug', 'createdAt']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.slug is string && data.slug.size() >= 1 && data.slug.size() <= 100 &&
             data.createdAt is timestamp;
    }

    function isValidSettings(data) {
      // Allow any fields as long as types are correct if present
      return (!('childName' in data) || data.childName is string) &&
             (!('fatherName' in data) || data.fatherName is string) &&
             (!('motherName' in data) || data.motherName is string) &&
             (!('eventDate' in data) || data.eventDate is string) &&
             (!('eventTime' in data) || data.eventTime is string) &&
             (!('address' in data) || data.address is string) &&
             (!('mapUrl' in data) || data.mapUrl is string) &&
             (!('heroImage' in data) || data.heroImage is string) &&
             (!('profileImage' in data) || data.profileImage is string) &&
             (!('gallery' in data) || (data.gallery is list && data.gallery.size() <= 10));
    }

    match /rsvps/{rsvpId} {
      // Publicly readable for the invitation
      allow read: if true;
      
      // Anyone can create an RSVP
      allow create: if isValidRSVP(request.resource.data) && 
                      request.resource.data.likes == 0 && 
                      request.resource.data.likedBy.size() == 0;
      
      // Update allowed for likes
      allow update: if isValidRSVP(request.resource.data) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']) &&
                      math.abs(request.resource.data.likes - resource.data.likes) == 1;
      
      // Admin can delete RSVPs
      allow delete: if isAdmin();
    }

    match /guests/{guestId} {
      // Only admin can manage guests
      allow read, write: if isAdmin() && (request.method != 'create' || isValidGuest(request.resource.data)) && (request.method != 'update' || isValidGuest(request.resource.data));
    }

    match /settings/{docId} {
      // Settings are publicly readable
      allow read: if true;
      // Only admin can update settings
      allow write: if isAdmin() && (request.method != 'create' || isValidSettings(request.resource.data)) && (request.method != 'update' || isValidSettings(request.resource.data));
    }
  }
}
