{
  "entities": {
    "RSVP": {
      "title": "RSVP",
      "description": "Guest RSVP and comments",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Guest name" },
        "attendance": { "type": "string", "enum": ["present", "absent"], "description": "Attendance status" },
        "message": { "type": "string", "description": "Guest message" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the RSVP was submitted" },
        "likes": { "type": "number", "description": "Number of likes" },
        "likedBy": { "type": "array", "items": { "type": "string" }, "description": "User IDs who liked this comment" }
      },
      "required": ["name", "attendance", "message", "timestamp", "likes", "likedBy"]
    },
    "Guest": {
      "title": "Guest",
      "description": "Guest list for personalized links",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Guest name" },
        "slug": { "type": "string", "description": "URL slug for the guest" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the guest was added" }
      },
      "required": ["name", "slug", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global invitation settings",
      "type": "object",
      "properties": {
        "childName": { "type": "string" },
        "fatherName": { "type": "string" },
        "motherName": { "type": "string" },
        "eventDate": { "type": "string" },
        "eventTime": { "type": "string" },
        "address": { "type": "string" },
        "mapUrl": { "type": "string" },
        "coordinates": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } } },
        "heroImage": { "type": "string" },
        "profileImage": { "type": "string" }
      },
      "required": ["childName", "fatherName", "motherName", "eventDate", "address"]
    }
  },
  "firestore": {
    "/rsvps/{rsvpId}": {
      "schema": "RSVP",
      "description": "Collection of guest RSVPs"
    },
    "/guests/{guestId}": {
      "schema": "Guest",
      "description": "Collection of guests for personalized links"
    },
    "/settings/global": {
      "schema": "Settings",
      "description": "Global configuration for the invitation"
    }
  }
}
